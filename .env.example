# Copy this file to `.env` and fill in your local values.
# The `.env` file is gitignored; this template is safe to commit.

# PostgreSQL connection string consumed by Prisma (prisma/schema.prisma).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lithdex?schema=public"

# Symmetric secret used to sign the session JWT. Must be at least 32 chars.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=""
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_VISION_MODEL=meta/llama-4-maverick-17b-128e-instruct
GOOGLE_APPLICATION_CREDENTIALS=.secrets/your-gcp-service-account.json
GCP_BUCKET_NAME=your-gcp-bucket-name
GCP_PROJECT_ID=your-gcp-project-id