# Copy this file to `.env` and fill in your local values.
# The `.env` file is gitignored; this template is safe to commit.

# PostgreSQL connection string used by Prisma.
# Local example:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lithdex?schema=public"

# Secret used to sign and verify the auth session JWT.
# Must be long and random. Recommended minimum: 32 characters.
# Example generation command:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=""

# NVIDIA API key used server-side for multimodal mineral analysis.
# Never expose this key to the client.
NVIDIA_API_KEY=""

# NVIDIA model identifier used for the guided analysis flow.
# Change this only if you intentionally switch models.
NVIDIA_VISION_MODEL="meta/llama-4-maverick-17b-128e-instruct"

# Local path to the Google Cloud service account JSON file.
# Used for development when authenticating to GCP from your machine.
# In production platforms like Vercel, this is usually replaced by
# direct environment-based credentials instead of a local file path.
GOOGLE_APPLICATION_CREDENTIALS=".secrets/your-gcp-service-account.json"

# Name of the private Google Cloud Storage bucket used to store analysis images.
GCP_BUCKET_NAME="your-gcp-bucket-name"

# Google Cloud project ID that owns the bucket and service account.
GCP_PROJECT_ID="your-gcp-project-id"